# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# Notion
NOTION_API_KEY=secret_...
NOTION_LEADS_DATABASE_ID=your-32-char-database-id

# Financial Data
TWELVE_DATA_API_KEY=your_key_here

# App
NEXT_PUBLIC_SITE_URL=https://eleusisfx.uk
NEXT_PUBLIC_WA_NUMBER=44XXXXXXXXXX

# Email (Resend — resend.com)
RESEND_API_KEY=re_...
RESEND_FROM=admin@eleusisfx.uk

# Instagram — Meta Graph API (instagram-live + post-instagram)
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id
# Token needs: instagram_basic, instagram_insights, instagram_content_publish
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token

# Telegram Bot — Chart Tool post-to-telegram
# 1. Create bot via @BotFather → get token
# 2. Add bot as admin to your channel
# 3. Get channel ID: @channelname or numeric -100xxxxxxxxxx
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:YYYYYYYYYYYYYYYYYYYYYYYYYYY
TELEGRAM_CHANNEL_ID=@yourchannel

# Chart Tool — local Puppeteer (dev only)
# Points to your local Chrome install. Override if Chrome is elsewhere.
# On macOS the default is used automatically; set this only if different.
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
